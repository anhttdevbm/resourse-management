# =============================================================================
# Resource Management System — Production environment
# Copy: cp product.env.example product.env  (then edit secrets)
# =============================================================================

# --- Public URL (used for CORS & frontend build) ---
PUBLIC_URL=http://localhost
CORS_ORIGINS=http://localhost,http://127.0.0.1
VITE_API_URL=

# --- Bootstrap admin (auto on deploy) ---
BOOTSTRAP_ADMIN_EMAIL=anhttdevbm@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@RMS2026!
BOOTSTRAP_ADMIN_NAME=Admin

# --- API ---
HOST=0.0.0.0
PORT=30111
WORKERS=2
LOG_LEVEL=INFO
IS_DEBUG=False
ENV=PROD
ENABLE_PUBLIC_REGISTRATION=True

# --- JWT ---
SECRET_KEY=change-this-secret-key-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- PostgreSQL ---
POSTGRES_USER=rms_admin
POSTGRES_PASSWORD=rms_db_password_change_me
POSTGRES_DB=resource_db
NAME_DB=resource_db
USERNAME_DB=rms_admin
PASSWORD_DB=rms_db_password_change_me
HOST_DB=db
PORT_DB=5432

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=rms_minio
MINIO_ROOT_PASSWORD=rms_minio_password_change_me
AWS_ACCESS_KEY_ID=rms_minio
AWS_SECRET_ACCESS_KEY=rms_minio_password_change_me
AWS_HOST=http://minio:9000
AWS_BUCKET_NAME=rms-files
AWS_REGION=ap-southeast-1

# --- Email (optional — password reset) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=noop@localhost
EMAIL_PASSWORD=noop
MAIL_USERNAME=noop@localhost
MAIL_PASSWORD=noop
FRONTEND_RESET_URL=http://localhost/reset-password
FRONTEND_URL=http://localhost

# --- OAuth (optional — để trống nếu không dùng) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=

# --- Redis (optional) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Upload limits ---
MAX_FILE_SIZE=104857600
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,txt,zip,rar,mp4,avi,mov,mp3,wav,exe,apk,iso

# --- Host ports (1070–1080) — map ra ngoài Docker ---
HTTP_PORT=1070
API_HOST_PORT=1071
POSTGRES_HOST_PORT=1072
MINIO_HOST_PORT=1073
MINIO_CONSOLE_HOST_PORT=1074

COMPOSE_PROJECT_NAME=rms
