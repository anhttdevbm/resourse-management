# =============================================================================
# Resource Management System — Backend environment (local / dev)
# Copy: cp .env.sample .env   (then edit secrets)
#
# Docker dev (back-end/cicd/docker): compose overrides HOST_DB=db,
# AWS_HOST=http://minio:9000 — không cần sửa hai biến đó trong .env.
# Chạy API trên máy host + DB/MinIO trong Docker: HOST_DB=localhost,
# AWS_HOST=http://localhost:9000
# Production full stack: dùng deploy/product.env.example → deploy/product.env
# =============================================================================

# --- Public URL & CORS ---
PUBLIC_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# --- Bootstrap admin (scripts/bootstrap_admin.py, chạy khi docker compose up) ---
BOOTSTRAP_ADMIN_EMAIL=admin@localhost.dev
BOOTSTRAP_ADMIN_EMAILS=anhttdevbm@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@Dev2026!
BOOTSTRAP_ADMIN_NAME=Admin

# --- Demo seed data (scripts/seed_demo_data.py, chạy khi docker compose up) ---
SEED_DEMO_DATA=true
SEED_DEMO_PASSWORD=Demo@2026!

# --- API ---
HOST=0.0.0.0
PORT=30111
WORKERS=1
ENV=DEV

# --- JWT ---
SECRET_KEY=change-this-secret-key-min-32-characters
SESSION_SECRET_KEY=change-this-session-secret-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- PostgreSQL (khớp back-end/cicd/docker/docker-compose.yml) ---
NAME_DB=resource_db
USERNAME_DB=admin
PASSWORD_DB=123456
HOST_DB=localhost
PORT_DB=5432

# --- MinIO (S3-compatible; boto3 dùng prefix AWS_* cho credential/endpoint nội bộ) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_HOST=http://localhost:9000
AWS_BUCKET_NAME=resource-management
AWS_REGION=ap-southeast-1
# URL MinIO mà trình duyệt gọi được (khác AWS_HOST khi API chạy trong Docker)
MINIO_PUBLIC_HOST=http://localhost:9000
MINIO_PRESIGN_EXPIRES=3600

# --- Email (optional — password reset) ---
# email_utils dùng SMTP_* + EMAIL_*; EmailService dùng MAIL_* (fallback EMAIL_*)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-app-password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
FRONTEND_URL=http://localhost:5173
FRONTEND_RESET_URL=http://localhost:5173/reset-password

# --- OAuth (optional — để trống nếu không dùng) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=

# --- Redis (optional) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Notifications (optional) ---
GOOGLE_CHAT_WEBHOOK=
