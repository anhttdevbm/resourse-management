COMPOSE_PROJECT_NAME=resource-management

PUBLIC_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
VITE_API_URL=http://localhost:30111

BOOTSTRAP_ADMIN_EMAIL=admin@localhost.dev
BOOTSTRAP_ADMIN_EMAILS=anhttdevbm@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe@Dev2026!
BOOTSTRAP_ADMIN_NAME=Admin

SEED_DEMO_DATA=true
SEED_DEMO_PASSWORD=Demo@2026!

HOST=0.0.0.0
PORT=30111
WORKERS=1
LOG_LEVEL=INFO
IS_DEBUG=True
ENV=DEV
ENABLE_PUBLIC_REGISTRATION=true

SECRET_KEY=dev-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_DB=resource_db
NAME_DB=resource_db
USERNAME_DB=admin
PASSWORD_DB=123456
HOST_DB=db
PORT_DB=5432

